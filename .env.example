# --- Required for Postgres (app + migrations) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Optional: postgres.js pool size (default 1 for *.supabase.* URLs to avoid “Max client connections reached”).
# DATABASE_POOL_MAX=2

# --- Required for sign-in and sign-up (Supabase Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_fG...

# --- Needed for member invites and deal PDF uploads (server-only) ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Optional ---
# Canonical site URL (redirects, links). If unset, Vercel may use VERCEL_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: “Try DEMO” on login/register (server-only). If unset, built-in demo credentials are used — change or remove for production.
# DEMO_LOGIN_EMAIL=
# DEMO_LOGIN_PASSWORD=

# Stripe: payments and webhooks (billing UI is limited without these keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
